require 'base64'
require 'fileutils'
require 'open3'
require 'shellwords'
require 'tmpdir'
require 'xcodeproj'

default_platform(:ios)

repo_root = File.expand_path('..', __dir__)
ios_dir = File.join(repo_root, 'ios')
android_dir = File.join(repo_root, 'android')
google_play_key = File.join(repo_root, 'google-play-service-account.json')
ios_app_identifier = 'com.eirikhanasand.Login'

platform :ios do
  lane :release do
    keychain_path = File.expand_path('~/Library/Keychains/login.keychain-db')
    asc_key_path = File.join(Dir.tmpdir, "app-store-connect-#{ENV.fetch('ASC_KEY_ID')}.p8")
    File.write(asc_key_path, Base64.decode64(ENV.fetch('ASC_PRIVATE_KEY_BASE64')))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch('ASC_KEY_ID'),
      issuer_id: ENV.fetch('ASC_ISSUER_ID'),
      key_content: File.read(asc_key_path),
      is_key_content_base64: false
    )

    sh("cd #{ios_dir.shellescape} && bundle exec pod install")

    get_certificates(
      api_key: api_key,
      development: false,
      keychain_path: keychain_path,
      keychain_password: ENV.fetch('MACOS_KEYCHAIN_PASSWORD')
    )
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{ENV.fetch('MACOS_KEYCHAIN_PASSWORD').shellescape} #{keychain_path.shellescape}")

    identities, identity_status = Open3.capture2('security', 'find-identity', '-v', '-p', 'codesigning', keychain_path)
    UI.user_error!("Unable to inspect code signing identities in #{keychain_path}") unless identity_status.success?
    signing_identity = identities[/"(Apple Distribution:[^"]+)"/, 1]
    UI.user_error!("No Apple Distribution identity found in #{keychain_path}") unless signing_identity

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: ios_app_identifier,
      force: false,
      skip_certificate_verification: true,
      skip_install: true
    )
    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH] || File.join(repo_root, "AppStore_#{ios_app_identifier}.mobileprovision")
    profile_plist, profile_status = Open3.capture2('openssl', 'smime', '-inform', 'der', '-verify', '-noverify', '-in', profile_path)
    UI.user_error!("Unable to decode provisioning profile at #{profile_path}") unless profile_status.success?

    profile_name = profile_plist[/<key>Name<\/key>\s*<string>([^<]+)<\/string>/, 1] || "#{ios_app_identifier} AppStore"
    profile_uuid = profile_plist[/<key>UUID<\/key>\s*<string>([^<]+)<\/string>/, 1]
    UI.user_error!("Unable to find UUID in provisioning profile at #{profile_path}") unless profile_uuid

    profiles_dir = File.expand_path('~/Library/MobileDevice/Provisioning Profiles')
    FileUtils.mkdir_p(profiles_dir)
    FileUtils.cp(profile_path, File.join(profiles_dir, "#{profile_uuid}.mobileprovision"))

    update_code_signing_settings(
      path: File.join(ios_dir, 'Login.xcodeproj'),
      use_automatic_signing: false,
      team_id: ENV.fetch('APPLE_TEAM_ID'),
      targets: ['Login'],
      build_configurations: ['Release'],
      profile_name: profile_name,
      code_sign_identity: signing_identity
    )
    project = Xcodeproj::Project.open(File.join(ios_dir, 'Login.xcodeproj'))
    project.build_configurations.each do |configuration|
      next unless configuration.name == 'Release'

      configuration.build_settings['CODE_SIGN_IDENTITY'] = signing_identity
      configuration.build_settings['CODE_SIGN_IDENTITY[sdk=iphoneos*]'] = signing_identity
      configuration.build_settings['DEVELOPMENT_TEAM'] = ENV.fetch('APPLE_TEAM_ID')
    end
    project.save

    build_app(
      workspace: File.join(ios_dir, 'Login.xcworkspace'),
      scheme: 'Login',
      configuration: 'Release',
      export_method: 'app-store',
      export_options: {
        signingStyle: 'manual',
        teamID: ENV.fetch('APPLE_TEAM_ID'),
        provisioningProfiles: {
          ios_app_identifier => profile_name
        }
      },
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID').shellescape}",
        "CODE_SIGN_IDENTITY=#{signing_identity.shellescape}",
        "CODE_SIGN_KEYCHAIN=#{keychain_path.shellescape}",
        "OTHER_CODE_SIGN_FLAGS=#{Shellwords.escape("--keychain #{keychain_path}")}"
      ].join(' ')
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end

platform :android do
  lane :release do
    gradle(
      task: 'bundle',
      build_type: 'Release',
      project_dir: android_dir
    )

    upload_to_play_store(
      json_key: google_play_key,
      package_name: 'com.login.Login',
      aab: File.join(android_dir, 'app/build/outputs/bundle/release/app-release.aab'),
      track: ENV.fetch('GOOGLE_PLAY_TRACK', 'production')
    )
  end
end
