require 'base64'
require 'shellwords'
require 'tmpdir'

default_platform(:ios)

repo_root = File.expand_path('..', __dir__)
ios_dir = File.join(repo_root, 'ios')
android_dir = File.join(repo_root, 'android')
google_play_key = File.join(repo_root, 'google-play-service-account.json')
ios_app_identifier = 'com.eirikhanasand.Login'

platform :ios do
  lane :release do
    asc_key_path = File.join(Dir.tmpdir, "app-store-connect-#{ENV.fetch('ASC_KEY_ID')}.p8")
    File.write(asc_key_path, Base64.decode64(ENV.fetch('ASC_PRIVATE_KEY_BASE64')))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch('ASC_KEY_ID'),
      issuer_id: ENV.fetch('ASC_ISSUER_ID'),
      key_content: File.read(asc_key_path),
      is_key_content_base64: false
    )

    sh("cd #{ios_dir.shellescape} && bundle exec pod install")

    get_certificates(
      api_key: api_key,
      development: false,
      keychain_password: ENV.fetch('MACOS_KEYCHAIN_PASSWORD')
    )

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: ios_app_identifier,
      force: true
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      path: File.join(ios_dir, 'Login.xcodeproj'),
      use_automatic_signing: false,
      team_id: ENV.fetch('APPLE_TEAM_ID'),
      targets: ['Login'],
      build_configurations: ['Release'],
      profile_name: profile_name,
      code_sign_identity: 'Apple Distribution'
    )

    build_app(
      workspace: File.join(ios_dir, 'Login.xcworkspace'),
      scheme: 'Login',
      configuration: 'Release',
      export_method: 'app-store',
      export_options: {
        signingStyle: 'manual',
        teamID: ENV.fetch('APPLE_TEAM_ID'),
        provisioningProfiles: {
          ios_app_identifier => profile_name
        }
      },
      xcargs: [
        '-allowProvisioningUpdates',
        "-authenticationKeyPath #{asc_key_path.shellescape}",
        "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID').shellescape}",
        "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID').shellescape}",
        "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID').shellescape}"
      ].join(' ')
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end

platform :android do
  lane :release do
    gradle(
      task: 'bundle',
      build_type: 'Release',
      project_dir: android_dir
    )

    upload_to_play_store(
      json_key: google_play_key,
      package_name: 'com.login.Login',
      aab: File.join(android_dir, 'app/build/outputs/bundle/release/app-release.aab'),
      track: ENV.fetch('GOOGLE_PLAY_TRACK', 'production')
    )
  end
end
