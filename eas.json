{
    "cli": {
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "node": "25.8.1",
            "env": {
                "PATH": "/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin"
            },
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "resourceClass": "m-medium"
            }
        },
        "preview": {
            "node": "25.8.1",
            "env": {
                "PATH": "/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin"
            },
            "distribution": "internal"
        },
        "production": {
            "node": "25.8.1",
            "env": {
                "PATH": "/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin"
            },
            "distribution": "store",
            "autoIncrement": true,
            "ios": {
                "resourceClass": "m-medium",
                "image": "latest"
            }
        }
    }
}
